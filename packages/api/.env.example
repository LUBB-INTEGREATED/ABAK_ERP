# Application
NODE_ENV=development
PORT=3001
API_GLOBAL_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# Database (wired in Issue #004)
DATABASE_URL="postgresql://user:password@localhost:5432/abak_erp?schema=public"

# JWT signing secret (REQUIRED in every environment).
# SR2-3: we deliberately do NOT ship the committed dev fallback here — boot
# hard-fails whenever JWT_SECRET equals it, regardless of NODE_ENV. Replace the
# placeholder below with a strong random value (>= 32 chars), e.g.
#   openssl rand -base64 48
# A fresh checkout fails fast until you set a real value.
JWT_SECRET=CHANGE_ME_min_32_random_chars

# Clerk Authentication (wired in Issue #005)
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
