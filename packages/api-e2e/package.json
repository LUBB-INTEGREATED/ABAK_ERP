{
  "name": "api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "api:build",
          "api:serve"
        ]
      }
    }
  },
  "devDependencies": {
    "@nx/node": "22.6.5",
    "@types/jest": "^30.0.0",
    "axios": "^1"
  }
}
