generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?

  role   UserRole   @default(SALES_REPRESENTATIVE)
  status UserStatus @default(ACTIVE)

  // Localization preferences (M9-008)
  preferredLanguage           String @default("ar") // 'ar' | 'en'
  calendarDisplay             String @default("BOTH") // GREGORIAN | HIJRI | BOTH
  numeralSystem               String @default("LATIN") // LATIN | ARABIC_INDIC
  timezone                    String @default("Asia/Riyadh")
  notificationQuietHoursStart Int?   @default(22)
  notificationQuietHoursEnd   Int?   @default(7)

  emailVerified        Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  refreshTokens      RefreshToken[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  managedClients     Client[]          @relation("AccountManager")
  loggedInteractions Interaction[]     @relation("InteractionAuthor")
  assignedFollowUps  FollowUp[]        @relation("FollowUpAssignee")
  authoredNotes      ClientNote[]      @relation("NoteAuthor")
  pipelineEntries    PipelineEntry[]   @relation("PipelineOwner")
  stageChanges       StageTransition[] @relation("StageActor")
  loggedVisits       FieldVisit[]      @relation("VisitAuthor")
  salesTargets       SalesTarget[]     @relation("TargetOwner")
  preparedQuotes     Quote[]           @relation("QuotePreparer")
  approvals          QuoteApproval[]   @relation("QuoteApprover")

  coordinatedRfqs     Rfq[] @relation("RfqCoordinator")
  technicalRfqs       Rfq[] @relation("RfqTechContributor")
  financialReviewRfqs Rfq[] @relation("RfqFinancialReviewer")
  originatedRfqs      Rfq[] @relation("RfqOriginalSalesRep")

  managedProjects Project[] @relation("ProjectPM")
  ownedPhases     Phase[]   @relation("PhaseOwner")
  assignedTasks   Task[]    @relation("TaskAssignee")

  validatedPayments                Payment[]                @relation("PaymentValidator")
  validatedCommercialConfirmations CommercialConfirmation[] @relation("CommercialConfirmationValidator")

  assignedGovTransactionsAsPro      GovTransaction[] @relation("GovTxPro")
  assignedGovTransactionsAsEngineer GovTransaction[] @relation("GovTxEngineer")
  loggedGovVisits                   GovVisit[]       @relation("GovVisitPro")
  respondedGovComments              GovComment[]     @relation("GovCommentResponder")

  notifications Notification[] @relation("NotificationRecipient")
  savedReports  SavedReport[]  @relation("ReportOwner")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // --- RBAC v2: department membership + data-roles ---
  departmentId      String?
  department        Department?      @relation("DepartmentMembers", fields: [departmentId], references: [id])
  managedDepartment Department?      @relation("DepartmentManager")
  roleAssignments   RoleAssignment[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([departmentId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REPRESENTATIVE
  TECHNICAL_MANAGER
  FINANCE_MANAGER
  PRO
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Service Catalog
// ============================================

/// ServiceCategory doubles as the "Department" in the 2026-05-21 process
/// correction. ABAK's departments (Architecture, Structural, MEP, Safety,
/// Surveying, Licensing, Supervision, ...) map 1:1 to the categories of
/// services they offer, so we reuse this model rather than introduce a
/// parallel `Department` table. RfqAssignment and QuoteItem both reference
/// it as their "department" anchor.
model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  nameAr      String?
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  services           Service[]
  rfqAssignments     RfqAssignment[]
  quoteItems         QuoteItem[]
  departmentSections QuoteDepartmentSection[]
  departmentLinks    DepartmentService[]
  quoteTemplates     QuoteTemplate[] // DOC-1: optional per-department template variant

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  nameAr      String?
  nameEn      String?
  description String?
  code        String  @unique

  basePrice Float?
  unit      String?

  isActive Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  leads    Lead[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  QuoteItem QuoteItem[]

  @@index([categoryId])
  @@index([code])
  @@map("services")
}

// ============================================
// System Configuration
// ============================================

model SystemSetting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(STRING)

  labelAr         String?
  labelEn         String?
  descriptionAr   String?
  descriptionEn   String?
  defaultValue    String?
  minValue        Float?
  maxValue        Float?
  editableByRoles String[] @default([])

  description String?
  category    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  history SettingHistory[]

  @@index([category])
  @@map("system_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model SettingHistory {
  id          String        @id @default(cuid())
  settingId   String
  setting     SystemSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  oldValue    String?
  newValue    String
  changedById String?
  changedAt   DateTime      @default(now())

  @@index([settingId])
  @@index([changedAt])
  @@map("setting_history")
}

// ============================================
// Public Holidays (M9-002)
// ============================================

model PublicHoliday {
  id          String   @id @default(cuid())
  date        DateTime // date-only, stored as UTC midnight
  nameAr      String
  nameEn      String
  isRecurring Boolean  @default(false)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([isRecurring])
  @@map("public_holidays")
}

// ============================================
// Saudi Arabia Regions (lookup table)
// ============================================

model Region {
  id       String  @id @default(cuid())
  code     String  @unique // e.g. "RYD", "MKH"
  nameAr   String
  nameEn   String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("regions")
}

// ============================================
// Module 1: Lead Capture & Reception
// ============================================

model Lead {
  id              String      @id @default(cuid())
  leadNumber      String      @unique
  channel         LeadChannel
  source          String?
  referenceNumber String?

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?

  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  serviceDetails  String?
  projectLocation String?
  projectSize     String?
  budget          Float?
  timeline        String?

  etimadNumber   String?
  fursaNumber    String?
  tenderDeadline DateTime?
  tenderDetails  Json?

  referredBy      String?
  referrerPhone   String?
  referrerCompany String?

  socialPlatform  String?
  socialProfile   String?
  socialUsername  String?
  relatedCampaign String?

  webSource String?

  mapsLink         String?
  mapsReview       Boolean?
  mapContactMethod String?
  mapHowFoundUs    String?

  city     String?
  district String?

  referralSourceType  String?
  expectedBudgetRange String?
  clientUrgency       String?

  status       LeadStatus   @default(INCOMING)
  priority     LeadPriority @default(MEDIUM)
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  slaResponseDue  DateTime?
  slaStatus       SLAStatus @default(ON_TIME)
  firstResponseAt DateTime?

  isReturningClient Boolean @default(false)
  clientId          String?
  client            Client? @relation(fields: [clientId], references: [id])

  pipelineEntry PipelineEntry?
  quotes        Quote[]
  /// Comms log entries scoped to this lead. See Interaction.
  interactions  Interaction[]  @relation("LeadInteractions")

  qualificationScore Int?    @default(0)
  qualificationNotes String?

  initialNotes String?
  lostReason   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  closedAt  DateTime?
  deletedAt DateTime?

  @@index([leadNumber])
  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([slaStatus])
  @@index([createdAt])
  @@index([serviceId])
  @@index([deletedAt])
  @@index([clientId])
  @@map("leads")
}

enum LeadChannel {
  REFERRAL
  WALK_IN
  PHONE
  EXISTING_CLIENT_REPEAT
  SOCIAL_MEDIA
  WEBSITE
  GOOGLE_MAPS
  AI_CHATBOT
  OTHER
}

enum LeadStatus {
  INCOMING
  ASSIGNED
  IN_PROGRESS
  QUALIFIED
  // Lead became a client (account created) and an RFQ/opportunity was raised.
  // Distinct from QUALIFIED so the conversion report can count it. Set by the
  // convert-to-client and request-RFQ flows; not a manual status transition.
  CONVERTED
  DISQUALIFIED
  TENDER_PENDING
  TENDER_ACTIVE
  TENDER_SUBMITTED
  TENDER_WON
  TENDER_LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SLAStatus {
  ON_TIME
  DUE_SOON
  OVERDUE
}

// ============================================
// Module 2: CRM (Client Relationship Management)
// ============================================

model Client {
  id           String @id @default(cuid())
  clientNumber String @unique

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  country      String? @default("Saudi Arabia")
  postalCode   String?

  commercialRegistration String?
  taxId                  String?

  clientType String?

  classification       ClientClassification @default(NEW)
  classificationManual Boolean              @default(false)
  status               ClientStatus         @default(ACTIVE)

  creditLimit  Float?
  paymentTerms String?

  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id])

  lifetimeValue     Float @default(0)
  satisfactionScore Int?

  notes           ClientNote[]
  interactions    Interaction[]
  followUps       FollowUp[]
  leads           Lead[]
  pipelineEntries PipelineEntry[]
  fieldVisits     FieldVisit[]
  quotes          Quote[]
  rfqs            Rfq[]
  purchaseOrders  PurchaseOrder[]
  projects        Project[]
  invoices        Invoice[]
  payments        Payment[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  lastInteractionAt DateTime?
  deletedAt         DateTime?

  @@index([clientNumber])
  @@index([classification])
  @@index([status])
  @@index([accountManagerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

enum ClientClassification {
  NEW
  RETURNING
  VIP
  DORMANT
  ARCHIVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

/// Communications log primitive. One entry per contact (call, WhatsApp, email,
/// meeting, site visit, ...). Can attach to a Lead, Client, Rfq, or Project —
/// at least one scope FK must be set (enforced at the application layer).
/// Per the 2026-05-21 process correction, this is the single thread-of-record
/// for client communication; the Sales Person owns it, and engineers logging
/// site-visit coordination CC the Sales Person via `ccAuthorIds`.
model Interaction {
  id String @id @default(cuid())

  // Scopes — at least one must be set. Client remains the canonical scope
  // for backward compatibility; lead/rfq/project added 2026-05-21.
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation("LeadInteractions", fields: [leadId], references: [id], onDelete: Cascade)
  rfqId     String?
  rfq       Rfq?     @relation("RfqInteractions", fields: [rfqId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation("ProjectInteractions", fields: [projectId], references: [id], onDelete: Cascade)

  type            InteractionType
  direction       InteractionDirection?
  visibility      InteractionVisibility @default(TEAM)
  subject         String
  summary         String?
  occurredAt      DateTime              @default(now())
  durationMinutes Int?

  location   String?
  outcome    String?
  nextAction String?

  authorId String?
  author   User?   @relation("InteractionAuthor", fields: [authorId], references: [id])

  /// Optional list of user IDs CC'd on this entry. Used when an engineer logs
  /// site-visit coordination and the responsible sales person needs to see it
  /// on their inbox / the lead's timeline.
  ccAuthorIds String[]

  /// Optional inline follow-up reminder. When set, the system surfaces the
  /// entry as an actionable follow-up on the Sales Person's queue.
  followUpDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([leadId])
  @@index([rfqId])
  @@index([projectId])
  @@index([type])
  @@index([occurredAt])
  @@index([authorId])
  @@map("interactions")
}

enum InteractionType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  COMPLAINT
  SITE_VISIT
  OFFICE_VISIT
  QUOTE_SENT_EVENT
  CONTRACT_SIGNED
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

enum InteractionVisibility {
  TEAM
  MANAGER_ONLY
  PRIVATE
}

model FollowUp {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        FollowUpType   @default(GENERAL)
  dueAt       DateTime
  status      FollowUpStatus @default(PENDING)

  assignedToId String?
  assignedTo   User?   @relation("FollowUpAssignee", fields: [assignedToId], references: [id])

  completedAt DateTime?
  outcome     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_ups")
}

enum FollowUpType {
  GENERAL
  QUOTE
  PAYMENT
  PROJECT_MILESTONE
  SATISFACTION_SURVEY
  RENEWAL
}

enum FollowUpStatus {
  PENDING
  DUE_TODAY
  OVERDUE
  COMPLETED
  CANCELLED
}

enum ClientSentiment {
  VERY_INTERESTED
  INTERESTED
  NEUTRAL
  HESITANT
  NOT_INTERESTED
}

model ClientNote {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  body     String
  tag      NoteTag @default(GENERAL)
  authorId String?
  author   User?   @relation("NoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([createdAt])
  @@map("client_notes")
}

enum NoteTag {
  GENERAL
  IMPORTANT
  ISSUE
  OPPORTUNITY
}

// ============================================
// Module 3: Sales Pipeline & Team Management
// ============================================

model PipelineEntry {
  id    String        @id @default(cuid())
  stage PipelineStage @default(NEW_LEAD)

  leadId   String? @unique
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("PipelineOwner", fields: [ownerId], references: [id])

  estimatedValue  Float?
  probability     Int?      @default(10)
  expectedCloseAt DateTime?
  stageEnteredAt  DateTime  @default(now())
  lostReason      String?
  postponedUntil  DateTime?

  transitions StageTransition[]
  rfq         Rfq?

  nextStep             String?
  nextStepDueDate      DateTime?
  decisionMakerName    String?
  decisionMakerContact String?
  expectedDecisionDate DateTime?
  readyForRfqAt        DateTime?

  isStuck    Boolean   @default(false)
  stuckSince DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([stage])
  @@index([ownerId])
  @@index([clientId])
  @@index([leadId])
  @@index([expectedCloseAt])
  @@index([isStuck])
  @@map("pipeline_entries")
}

enum PipelineStage {
  NEW_LEAD
  FIRST_CONTACT_MADE
  MEETING_SCHEDULED
  MEETING_DONE
  READY_FOR_RFQ
  RFQ_SUBMITTED
  QUOTE_IN_PREPARATION
  QUOTE_SENT_TO_CLIENT
  NEGOTIATION_REVISION
  WON
  LOST
  POSTPONED
}

model StageTransition {
  id              String        @id @default(cuid())
  pipelineEntryId String
  pipelineEntry   PipelineEntry @relation(fields: [pipelineEntryId], references: [id], onDelete: Cascade)

  fromStage PipelineStage
  toStage   PipelineStage
  reason    String?

  actorId String?
  actor   User?   @relation("StageActor", fields: [actorId], references: [id])

  durationSeconds Int?
  occurredAt      DateTime @default(now())

  @@index([pipelineEntryId])
  @@index([occurredAt])
  @@map("stage_transitions")
}

model FieldVisit {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  visitType       VisitType
  purpose         String
  keyOutcomes     String?
  findings        String?
  nextAction      String?
  clientSentiment ClientSentiment?

  scheduledAt    DateTime
  completedAt    DateTime?
  locationLabel  String?
  latitude       Float?
  longitude      Float?
  attendees      String?
  attachmentUrls String[]  @default([])

  authorId String?
  author   User?   @relation("VisitAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([authorId])
  @@index([scheduledAt])
  @@map("field_visits")
}

enum VisitType {
  CLIENT_OFFICE
  SITE
  ABAK_OFFICE
  VIRTUAL
  EVENT
}

model SalesTarget {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("TargetOwner", fields: [ownerId], references: [id])

  type          TargetType
  period        TargetPeriod
  periodStart   DateTime
  periodEnd     DateTime
  targetValue   Float
  achievedValue Float        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, type, period, periodStart])
  @@index([ownerId])
  @@map("sales_targets")
}

enum TargetType {
  REVENUE
  QUOTES_SENT
  CONVERSIONS
  VISITS
}

enum TargetPeriod {
  MONTHLY
  QUARTERLY
}

// ============================================
// Module 4: Quotation & Pricing Engine
// ============================================

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  version     Int         @default(1)
  status      QuoteStatus @default(DRAFT)

  clientId String
  client   Client  @relation(fields: [clientId], references: [id])
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id])

  title              String
  description        String?
  scopeOfWork        String?
  deliverables       String?
  exclusions         String?
  assumptions        String?
  numberOfRevisions  Int?
  validUntil         DateTime?
  deliveryTimeline   String?
  paymentTerms       String?
  termsAndConditions String?
  internalNotes      String?
  clientNotes        String?

  subtotal       Float        @default(0)
  discountType   DiscountType @default(FIXED)
  discountValue  Float        @default(0)
  discountAmount Float        @default(0)
  taxRate        Float        @default(15)
  taxAmount      Float        @default(0)
  totalAmount    Float        @default(0)

  /// DOC-2: snapshot-on-issue. Resolved template + org content (about/bank/
  /// contact) + assets, serialized on SEND so a re-opened sent quote renders
  /// AS-ISSUED even after the template/profile later change. Null = render live.
  renderManifest Json?

  preparedById String?
  preparedBy   User?   @relation("QuotePreparer", fields: [preparedById], references: [id])

  sentAt         DateTime?
  viewedAt       DateTime?
  wonAt          DateTime?
  lostAt         DateTime?
  lostReasonCode LossReason?
  lostReason     String?
  postponedUntil DateTime?
  cancelledAt    DateTime?

  parentQuoteId String?
  parentQuote   Quote?  @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions     Quote[] @relation("QuoteRevisions")

  items                  QuoteItem[]
  departmentSections     QuoteDepartmentSection[]
  requirements           QuoteRequirement[]
  paymentMilestones      PaymentMilestone[]
  approvals              QuoteApproval[]
  purchaseOrder          PurchaseOrder?
  rfq                    Rfq?
  commercialConfirmation CommercialConfirmation?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([quoteNumber])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([preparedById])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  IN_REVISION
  APPROVED
  SENT
  IN_DISCUSSION
  IN_NEGOTIATION
  REVISED
  WON
  LOST
  POSTPONED
  EXPIRED
  CANCELLED
}

// BR-11 — loss reasons come from a controlled vocabulary (doc PART 3.4)
enum LossReason {
  PRICE
  COMPETITOR
  SCOPE_MISMATCH
  BUDGET_UNAVAILABLE
  POSTPONED
  NO_RESPONSE
  QUALITY_CONCERN
  INTERNAL
  OTHER
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

model QuoteItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  /// Multi-dept quote support (2026-05-21 process correction).
  /// Groups line items into department sections on the quote builder
  /// and on the printed PDF. References ServiceCategory which doubles
  /// as the catalog of internal departments.
  departmentId String?
  department   ServiceCategory? @relation(fields: [departmentId], references: [id])

  /// DM-3: the Quote department section this line belongs to (lead-pricer
  /// compile model). Nullable for legacy/manual quotes with no sections.
  sectionId String?
  section   QuoteDepartmentSection? @relation(fields: [sectionId], references: [id])

  description String
  quantity    Float
  unit        String?
  unitPrice   Float
  discountPct Float   @default(0)
  subtotal    Float   @default(0)
  notes       String?
  position    Int     @default(0)

  /// Optional methodology card rendered on page 5 of the canonical PDF.
  methodologyCard MethodologyCard?
  /// Optional gantt block rendered on page 6 of the canonical PDF.
  ganttBlock      GanttBlock?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([departmentId])
  @@index([sectionId])
  @@map("quote_items")
}

/// DM-3: per-department section of a multi-dept quote. One row per involved
/// Department (ServiceCategory). The lead pricer compiles all sections; each
/// dept pricer fills its own and flips it to SUBMITTED_TO_LEAD.
model QuoteDepartmentSection {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  departmentId String
  department   ServiceCategory @relation(fields: [departmentId], references: [id])

  /// The engineer pricing this section (nullable until a pricer is assigned).
  pricerId String?

  /// Page-3 per-dept scope narrative (bilingual).
  scopeTextAr String?
  scopeTextEn String?

  /// Exactly one section per quote is the lead (compiles + submits the whole).
  isLead Boolean @default(false)

  status       QuoteSectionStatus @default(DRAFT)
  /// Drives per-visit presentation in the price-offer document.
  pricingModel DeptPricingModel   @default(LUMP_SUM)

  items QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quoteId, departmentId])
  @@index([quoteId])
  @@index([departmentId])
  @@map("quote_department_sections")
}

enum QuoteSectionStatus {
  DRAFT
  SUBMITTED_TO_LEAD
}

enum DeptPricingModel {
  LUMP_SUM
  PER_VISIT // qty = N visits, unitPrice = price/visit (e.g. Supervision)
  PER_UNIT
}

/// DM-3: a requirement/note line on the quote. The lead reviewer dedups shared
/// requirements across department sections into one isShared row, recording the
/// per-section sources in dedupedFromIds.
model QuoteRequirement {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // TODO(spec): requirement type values aren't enumerated in the roadmap;
  // DOCUMENT (client must provide) vs NOTE (free-text clarification) covers
  // §14's "requirements/notes" dedup. Revisit if the spec pins more types.
  type           QuoteRequirementType @default(NOTE)
  text           String
  /// True once the lead reviewer merges duplicate per-section lines into one.
  isShared       Boolean              @default(false)
  /// Source QuoteRequirement ids merged into this shared row (audit of dedup).
  dedupedFromIds String[]             @default([])
  position       Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_requirements")
}

enum QuoteRequirementType {
  DOCUMENT
  NOTE
}

// ============================================
// EPIC 4 — Price-offer document composition (DOC-1)
// Key off ServiceCategory.id; snapshot-on-issue (Quote.renderManifest, DOC-2).
// ============================================

/// DOC-1: the 8-block (or N-block) document layout. Org-level default, with an
/// optional per-department (ServiceCategory) variant. Snapshot-on-issue =
/// immutable once published (clone to a new version to change).
model QuoteTemplate {
  id        String  @id @default(cuid())
  name      String
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  /// Optional per-department variant (ServiceCategory grain, per the spec). Null
  /// = the org default. P3 may drop variants for v1.
  departmentId String?
  department   ServiceCategory? @relation(fields: [departmentId], references: [id])

  /// Snapshot-on-issue versioning: immutable once publishedAt is set; clone to
  /// a new version (parentId chain) to edit.
  version     Int             @default(1)
  publishedAt DateTime?
  parentId    String?
  parent      QuoteTemplate?  @relation("QuoteTemplateVersions", fields: [parentId], references: [id])
  versions    QuoteTemplate[] @relation("QuoteTemplateVersions")

  sections QuoteTemplateSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
  @@index([departmentId])
  @@map("quote_templates")
}

enum QuoteSectionType {
  COVER
  ABOUT
  SCOPE_PRICING
  PAYMENT
  METHODOLOGY
  TIMELINE
  REQUIREMENTS_NOTES
  THANKYOU
  IMAGE_PAGE
  CUSTOM_RICHTEXT
}

enum QuoteSectionBinding {
  DATA_BOUND // rendered from quote/section data
  UPLOADED_IMAGE // a full-page QuoteAsset image
  STATIC_CONTENT // org/template static copy
}

/// DOC-1: one block of a template. position + enabled drive ordering/visibility;
/// config is per-section JSON (e.g. heading overrides, column toggles).
model QuoteTemplateSection {
  id         String        @id @default(cuid())
  templateId String
  template   QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  sectionType QuoteSectionType
  bindingType QuoteSectionBinding @default(DATA_BOUND)
  position    Int                 @default(0)
  enabled     Boolean             @default(true)

  /// For UPLOADED_IMAGE blocks (cover background, full-page images).
  assetId String?
  asset   QuoteAsset? @relation(fields: [assetId], references: [id])

  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@map("quote_template_sections")
}

enum QuoteAssetKind {
  COVER_BACKGROUND
  LOGO
  FULL_PAGE_IMAGE
  SIGNATURE
}

/// DOC-1: a full-page image / cover background / logo for a template block.
/// `fileAssetId` points at the UP-1 FileAsset byte store (loose ref, no cascade).
model QuoteAsset {
  id          String         @id @default(cuid())
  url         String
  kind        QuoteAssetKind @default(FULL_PAGE_IMAGE)
  label       String?
  fileAssetId String?

  templateSections QuoteTemplateSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quote_assets")
}

/// DOC-1: org-level content for the document (about, services, accreditations,
/// contact, and the sensitive BANK details). Singleton in practice (one active).
/// Bank writes are gated by `company_profile.manage` + logged in
/// CompanyProfileHistory (blocker #7).
model CompanyProfile {
  id       String  @id @default(cuid())
  isActive Boolean @default(true)

  // About / who-we-are
  legalName      String
  legalNameAr    String?
  aboutText      String?
  aboutTextAr    String?
  /// string[] or {name,nameAr}[] of services + accreditations (bilingual arrays).
  services       Json?
  accreditations Json?

  // Contact
  phone     String?
  email     String?
  website   String?
  address   String?
  addressAr String?
  logoUrl   String?

  // Bank (sensitive — company_profile.manage + history audit)
  bankName        String?
  bankAccountName String?
  iban            String?
  swift           String?

  history CompanyProfileHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("company_profiles")
}

/// DOC-1 / blocker #7: append-only audit of CompanyProfile changes (esp. IBAN).
model CompanyProfileHistory {
  id        String         @id @default(cuid())
  profileId String
  profile   CompanyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  field       String
  oldValue    String?
  newValue    String?
  changedById String?
  changedAt   DateTime @default(now())

  @@index([profileId])
  @@map("company_profile_history")
}

/// Per-line methodology card (description + steps + deliverable). Optional;
/// when present, the auto-generated PDF includes the methodology page.
/// 2026-05-21 process correction — see docs/CORRECTED_CLIENT_JOURNEY.md §4.
model MethodologyCard {
  id          String    @id @default(cuid())
  quoteItemId String    @unique
  quoteItem   QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  description String
  /// Ordered list of method steps (3–5 bullets typically). Stored as
  /// JSON array of strings for editor simplicity.
  steps       Json   @default("[]")
  deliverable String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("methodology_cards")
}

/// Per-line gantt block. Optional; when present, the auto-generated PDF
/// includes the project timeline page. Co-existing across line items
/// renders the multi-bar Gantt with per-department tone.
model GanttBlock {
  id          String    @id @default(cuid())
  quoteItemId String    @unique
  quoteItem   QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  startDay     Int
  durationDays Int
  /// Hex string ('#2d7ad1') or named tone key — used as bar fill on Gantt.
  categoryTone String @default("#2d7ad1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gantt_blocks")
}

model PaymentMilestone {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description   String
  percentage    Float
  amount        Float
  daysFromStart Int?
  notes         String?
  position      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("payment_milestones")
}

model QuoteApproval {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  tier       Int
  approverId String
  approver   User   @relation("QuoteApprover", fields: [approverId], references: [id])

  status    ApprovalStatus @default(PENDING)
  decidedAt DateTime?
  comments  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([approverId])
  @@index([status])
  @@map("quote_approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique

  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  project  Project?
  invoices Invoice[]
  payments Payment[]

  poDate               DateTime  @default(now())
  startDate            DateTime?
  expectedCompletionAt DateTime?
  contractValue        Float
  status               POStatus  @default(ACTIVE)
  contractDocUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poNumber])
  @@index([clientId])
  @@index([status])
  @@map("purchase_orders")
}

enum POStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String

  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Module 3 — RFQ (Request For Quotation)  (M3-004)
// ============================================

model Rfq {
  id        String @id @default(cuid())
  rfqNumber String @unique

  opportunityId String        @unique
  opportunity   PipelineEntry @relation(fields: [opportunityId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])

  serviceType  String
  projectScope String
  priority     RfqPriority @default(NORMAL)

  /// ServiceCategory ids the sales rep selected when raising the RFQ. Drives
  /// department routing/visibility (DepartmentService maps category -> dept ->
  /// managerId) and lets a routed-but-unassigned RFQ be visible to the dept
  /// managers who must assign pricers. See requestRfq + rfqs.list DEPARTMENT branch.
  requestedCategoryIds String[] @default([])

  requestedByChannel RfqSource
  brokerName         String?
  brokerPhone        String?

  coordinatorId         String?
  coordinator           User?     @relation("RfqCoordinator", fields: [coordinatorId], references: [id])
  coordinatorAssignedAt DateTime?

  technicalContributorId String?
  technicalContributor   User?   @relation("RfqTechContributor", fields: [technicalContributorId], references: [id])

  financialReviewerId String?
  financialReviewer   User?   @relation("RfqFinancialReviewer", fields: [financialReviewerId], references: [id])

  originalSalesRepId String?
  originalSalesRep   User?   @relation("RfqOriginalSalesRep", fields: [originalSalesRepId], references: [id])

  status RfqStatus @default(SUBMITTED)

  // DM-1 decline ("Not us") audit — set by declineRfq
  declineType   RfqDeclineType?
  declineReason String?
  declinedById  String?
  declinedAt    DateTime?

  quoteId       String?             @unique
  quote         Quote?              @relation(fields: [quoteId], references: [id])
  dispatchedAt  DateTime?
  dispatchedVia RfqDispatchChannel?

  confirmationType   ConfirmationType?
  confirmationAt     DateTime?
  confirmationValue  Float?
  confirmationDocUrl String?

  lostReason     String?
  postponedUntil DateTime?

  qualityScore  RfqQualityScore @default(PENDING)
  revisionCount Int             @default(0)

  commissions Commission[]

  /// Comms log entries scoped to this RFQ (e.g. site-visit coordination,
  /// document request follow-up). See Interaction.
  interactions Interaction[] @relation("RfqInteractions")

  /// Per-department pricer assignments. One row per department involved.
  /// Exactly one row across the whole RFQ must have isLeadPricer = true.
  /// 2026-05-21 process correction — see docs/CORRECTED_CLIENT_JOURNEY.md §C.
  assignments       RfqAssignment[]
  docRequests       RfqDocRequest[]
  siteVisitRequests RfqSiteVisitRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([rfqNumber])
  @@index([clientId])
  @@index([coordinatorId])
  @@index([status])
  @@index([createdAt])
  @@map("rfqs")
}

/// Per-department pricer assignment on an RFQ. The Department Manager
/// (or Sales Manager for multi-dept) picks one engineer per department;
/// exactly one of those engineers carries the `isLeadPricer = true` flag.
/// The Lead Pricer sees and submits the consolidated quote; non-lead
/// assignees only see + submit their own section.
model RfqAssignment {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  /// Engineer (or manager) responsible for this department's section.
  /// Plain string FK to avoid a User back-relation cascade.
  assigneeId String

  departmentId String
  department   ServiceCategory @relation(fields: [departmentId], references: [id])

  /// Exactly one row across the RFQ should be true. Enforced at the
  /// service layer (Prisma doesn't support partial unique indexes here).
  isLeadPricer Boolean @default(false)

  status      RfqAssignmentStatus @default(IN_PROGRESS)
  assignedAt  DateTime            @default(now())
  submittedAt DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rfqId, departmentId])
  @@index([rfqId])
  @@index([assigneeId])
  @@index([departmentId])
  @@map("rfq_assignments")
}

enum RfqAssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  REVISION_REQUESTED
}

/// Engineer-to-sales-person document request raised while pricing an RFQ.
/// The pricer needs an extra document from the client (CR, soil report,
/// etc.); request lands in the sales person's inbox; the sales person
/// resolves with the document attached.
model RfqDocRequest {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  requestedById String
  description   String
  status        RfqRequestStatus @default(PENDING)
  response      String?
  attachmentUrl String?
  resolvedById  String?
  resolvedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([status])
  @@map("rfq_doc_requests")
}

/// Engineer's request for a site visit before pricing. The sales person
/// is notified for first contact; the engineer can then coordinate
/// directly with the client (CC'd via Interaction.ccAuthorIds).
model RfqSiteVisitRequest {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  requestedById     String
  purpose           String
  preferredDateFrom DateTime?
  preferredDateTo   DateTime?
  status            RfqRequestStatus @default(PENDING)
  scheduledAt       DateTime?
  completedAt       DateTime?
  notes             String?

  // DM-13: on-site access contact the sales responder confirms when scheduling.
  accessContactName  String?
  accessContactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([status])
  @@map("rfq_site_visit_requests")
}

enum RfqRequestStatus {
  PENDING
  RESOLVED
  CANCELLED
}

// DM-1: thin RFQ. Lifecycle/terminal states (SENT/WON/LOST/POSTPONED/…) now
// live ONLY on the Quote; the sales-facing display status is DERIVED from
// rfq.quote.status (see rfq-display-status.ts). RFQ keeps only intake states.
enum RfqStatus {
  SUBMITTED // was RECEIVED — raised by sales, awaiting dept triage
  ASSIGNED // pricers assigned, no draft quote yet (optional intermediate)
  PRICING // accept+assign fired startPricing → quote exists & is being built
  CANCELLED // sales-side cancel
  DECLINED // dept said "not us" (wrong_dept | no_bid)
}

enum RfqDeclineType {
  WRONG_DEPT // route back to sales as needs-re-route
  NO_BID // close out as no-bid
}

enum RfqSource {
  SALES_MANAGER
  INTERNAL_REP
  BROKER
  SOCIAL
  EMAIL
  WHATSAPP
}

enum RfqPriority {
  NORMAL
  HIGH
  URGENT
}

enum RfqDispatchChannel {
  WHATSAPP
  EMAIL
}

enum ConfirmationType {
  PAYMENT
  PO
  CONTRACT
}

enum RfqQualityScore {
  HIGH
  MEDIUM
  LOW
  PENDING
}

// ============================================
// Module 5 — Project Execution (M5-001)
// ============================================

model Project {
  id            String @id @default(cuid())
  projectNumber String @unique

  poId String        @unique
  po   PurchaseOrder @relation(fields: [poId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  opportunityId String?
  rfqId         String?

  title       String
  description String?

  pmId String
  pm   User   @relation("ProjectPM", fields: [pmId], references: [id])

  status          ProjectStatus @default(PLANNING)
  startDate       DateTime?
  expectedEndDate DateTime?
  actualEndDate   DateTime?

  contractValue   Float
  plannedProgress Float @default(0)
  actualProgress  Float @default(0)

  financialRiskFlagged   Boolean   @default(false)
  financialRiskFlaggedAt DateTime?
  financialRiskReason    String?

  phases           Phase[]
  tasks            Task[]
  closureChecklist ClosureChecklist?
  invoices         Invoice[]
  govTransactions  GovTransaction[]
  /// Comms log entries scoped to this project. See Interaction.
  interactions     Interaction[]     @relation("ProjectInteractions")
  /// Project-scoped government licences. Replaces the standalone
  /// GovTransaction model per the 2026-05-21 process correction.
  licences         Licence[]

  /// Timeline state. Active = phases running on schedule.
  /// Paused = at least one due-to-start phase is blocked by a non-issued
  /// licence dependency; pause intervals are excluded from slip math.
  timelineState      ProjectTimelineState @default(ACTIVE)
  /// Cumulative duration (in seconds) this project has spent Paused due to
  /// licence dependencies. Used to back out paused time from slip reports.
  pausedSecondsTotal Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([projectNumber])
  @@index([clientId])
  @@index([pmId])
  @@index([status])
  @@map("projects")
}

enum ProjectTimelineState {
  ACTIVE
  PAUSED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  AT_RISK
  CLOSING
  CLOSED
  CANCELLED
}

model Phase {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  phaseCode   PhaseCode
  customLabel String?

  position Int
  ownerId  String
  owner    User   @relation("PhaseOwner", fields: [ownerId], references: [id])

  status       PhaseStatus @default(NOT_STARTED)
  plannedStart DateTime
  plannedEnd   DateTime
  actualStart  DateTime?
  actualEnd    DateTime?

  progressPct      Float   @default(0)
  pmAdjustment     Float?
  pmAdjustmentNote String?

  evidenceRequired     Boolean   @default(true)
  evidenceNote         String?
  clientAcknowledgedAt DateTime?
  completedAt          DateTime?
  completedById        String?

  tasks Task[]

  /// Government licences whose `Issued` status this phase depends on.
  /// While any dependency is not yet `Issued`, the phase is hard-blocked
  /// from starting (UI-level guard) and the parent project enters a
  /// PAUSED timelineState. See Licence + ProjectTimelineState.
  licenceDependencies Licence[] @relation("PhaseLicenceDependencies")

  /// Set when the engineer / PM requests a phase-block exemption from the
  /// CEO (e.g., "start work on the building permit before it's issued").
  /// Justification + audit logged; only granted via the CEO surface.
  licenceOverrideJustification String?
  licenceOverrideById          String?
  licenceOverrideAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
  @@map("phases")
}

enum PhaseCode {
  INITIATION
  KICKOFF
  EXECUTION
  REVIEW
  SUBMISSION
  REVISIONS
  CLOSURE
  CUSTOM
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  UNDER_REVIEW
  COMPLETED
  SKIPPED
}

model Task {
  id        String  @id @default(cuid())
  projectId String
  phaseId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  assigneeId  String?
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  status   TaskStatus   @default(NOT_STARTED)
  priority TaskPriority @default(NORMAL)

  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  estimatedHours Float?
  actualHours    Float?

  blockers   TaskDependency[] @relation("DependentTask")
  dependents TaskDependency[] @relation("BlockerTask")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
  @@index([assigneeId])
  @@map("tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model TaskDependency {
  id          String @id @default(cuid())
  dependentId String
  blockerId   String
  dependent   Task   @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)
  blocker     Task   @relation("BlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([dependentId, blockerId])
  @@map("task_dependencies")
}

// PART 7 — Project Closure (M5-011)
model ClosureChecklist {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // PM-owned gates
  allPhasesCompleted         Boolean   @default(false)
  allPhasesCompletedAt       DateTime?
  allPhasesCompletedById     String?
  deliverablesSubmitted      Boolean   @default(false)
  deliverablesSubmittedAt    DateTime?
  deliverablesSubmittedById  String?
  clientApprovalReceived     Boolean   @default(false)
  clientApprovalReceivedAt   DateTime?
  clientApprovalReceivedById String?

  // Finance-owned gates
  finalPaymentReceived       Boolean   @default(false)
  finalPaymentReceivedAt     DateTime?
  finalPaymentReceivedById   String?
  financeClearanceIssued     Boolean   @default(false)
  financeClearanceIssuedAt   DateTime?
  financeClearanceIssuedById String?

  initiatedAt   DateTime  @default(now())
  initiatedById String?
  closedAt      DateTime?

  @@map("closure_checklists")
}

// ============================================
// Module 7 — Finance (Invoices, Payments, Commercial Confirmations, Commissions)
// ============================================

model CommercialConfirmation {
  id      String @id @default(cuid())
  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])

  type          ConfirmationType
  confirmedAt   DateTime         @default(now())
  contractValue Float
  docUrl        String?
  notes         String?

  validationStatus PaymentValidationStatus @default(PENDING)
  validatedAt      DateTime?
  validatedById    String?
  validatedBy      User?                   @relation("CommercialConfirmationValidator", fields: [validatedById], references: [id])
  validationNote   String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([validationStatus])
  @@map("commercial_confirmations")
}

enum PaymentValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  poId     String
  po       PurchaseOrder @relation(fields: [poId], references: [id])
  clientId String
  client   Client        @relation(fields: [clientId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  milestoneId String?

  issueDate   DateTime @default(now())
  dueDate     DateTime
  subtotal    Float
  taxAmount   Float
  totalAmount Float

  status InvoiceStatus @default(ISSUED)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([invoiceNumber])
  @@index([poId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Payment {
  id            String @id @default(cuid())
  paymentNumber String @unique

  invoiceId String?
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id])
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id])
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])

  receivedAt      DateTime
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  docUrl          String?

  validationStatus PaymentValidationStatus @default(PENDING)
  validatedAt      DateTime?
  validatedById    String?
  validatedBy      User?                   @relation("PaymentValidator", fields: [validatedById], references: [id])
  validationNote   String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([invoiceId])
  @@index([poId])
  @@index([clientId])
  @@index([validationStatus])
  @@map("payments")
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  ONLINE
  OTHER
}

model Commission {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id])

  beneficiaryType   CommissionBeneficiary
  beneficiaryName   String
  beneficiaryPhone  String?
  beneficiaryUserId String?

  baseAmount Float            @default(0)
  rate       Float
  amount     Float            @default(0)
  status     CommissionStatus @default(ACCRUING)
  paidAt     DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([status])
  @@map("commissions")
}

enum CommissionBeneficiary {
  BROKER
  SALES_REP
  REFERRAL_SOURCE
}

enum CommissionStatus {
  ACCRUING
  APPROVED
  PAID
  CANCELLED
}

// ============================================
// Module 6 — Government Transactions (M6-001)
// ============================================

model GovTransaction {
  id                String @id @default(cuid())
  transactionNumber String @unique

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorityName     String
  authorityCategory GovAuthorityCategory
  transactionType   String
  referenceNumber   String?

  assignedProId      String?
  assignedPro        User?   @relation("GovTxPro", fields: [assignedProId], references: [id])
  assignedEngineerId String?
  assignedEngineer   User?   @relation("GovTxEngineer", fields: [assignedEngineerId], references: [id])

  submittedAt        DateTime?
  expectedResponseAt DateTime?
  resolvedAt         DateTime?

  status     GovTxStatus @default(SUBMITTED)
  fees       Float?
  feesPaid   Boolean     @default(false)
  feesPaidAt DateTime?

  weeklyStatusLastAt DateTime?

  visits    GovVisit[]
  comments  GovComment[]
  documents GovDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([projectId])
  @@index([transactionNumber])
  @@index([assignedProId])
  @@index([status])
  @@map("gov_transactions")
}

enum GovAuthorityCategory {
  MUNICIPALITY
  MINISTRY
  UTILITY
  PLATFORM_ETIMAD
  PLATFORM_FURSA
  OTHER
}

enum GovTxStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUIRED
  APPROVED
  REJECTED
  CANCELLED
}

model GovVisit {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  visitedById String
  visitedBy   User     @relation("GovVisitPro", fields: [visitedById], references: [id])
  visitedAt   DateTime
  purpose     String
  outcome     String?
  nextAction  String?
  latitude    Float?
  longitude   Float?
  attachments Json?

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([visitedById])
  @@index([visitedAt])
  @@map("gov_visits")
}

model GovComment {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  commentText   String
  issuedAt      DateTime
  responseText  String?
  respondedAt   DateTime?
  respondedById String?
  respondedBy   User?     @relation("GovCommentResponder", fields: [respondedById], references: [id])

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@map("gov_comments")
}

model GovDocument {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  title      String
  fileUrl    String
  mimeType   String?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@index([transactionId])
  @@map("gov_documents")
}

// ============================================
// Sprint 8 — Notifications (M8-001)
// ============================================

model Notification {
  id          String @id @default(cuid())
  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  eventCode String
  subject   String
  body      String
  locale    String               @default("ar")
  priority  NotificationPriority @default(NORMAL)

  deepLink String?
  payload  Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([eventCode])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// Sprint 11 — File Assets (M11-002)
// ============================================
//
// Minimum viable: assets are registered by URL (S3/CDN/etc). Direct upload
// + presign + virus scan deferred. Feature flag-free by design.

model FileAsset {
  id              String  @id @default(cuid())
  url             String
  originalName    String
  mimeType        String
  sizeBytes       Int
  uploadedById    String?
  ownerResource   String?
  ownerResourceId String?
  // SR2-2 / SR2-3: default-deny. The @Public /raw route serves ONLY assets
  // explicitly flagged public (e.g. the company logo). Everything else —
  // including null/unknown-owner uploads (RFQ doc-request attachments) — is
  // refused on /raw and gated behind the authenticated /download ACL.
  isPublic        Boolean @default(false)

  createdAt DateTime @default(now())

  // WS-D: a FileAsset may back a Document record (entity-linked document).
  documents Document[]

  @@index([ownerResource, ownerResourceId])
  @@map("file_assets")
}

// ============================================
// WS-D · Document Control (Wave-0) — DOC-A
// A central document model linking the existing FileAsset store to any business
// entity (project / gov-tx / quote / client / lead / finance). Wave-0 is basic
// document management: upload, categorise, list-by-entity, download — NO
// version/Rev/stamp/diff (that is the deferred DOC-B wave). Access is gated by
// the OWNING entity's scope (the documents service re-runs the owning module's
// object-level scope check), so a user only sees docs for entities they can see.
// ============================================

enum DocumentEntityType {
  PROJECT
  GOV_TX
  QUOTE
  CLIENT
  LEAD
  FINANCE
}

enum DocumentCategory {
  ARCHITECTURAL
  STRUCTURAL
  LICENSE
  FINANCIAL
  CONTRACT
  OTHER
}

model Document {
  id           String             @id @default(cuid())
  fileAssetId  String
  fileAsset    FileAsset          @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  entityType   DocumentEntityType
  entityId     String
  category     DocumentCategory   @default(OTHER)
  title        String
  uploadedById String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@map("documents")
}

// ============================================
// Sprint 11 — Escalation Ladder (M11-007, PART 8)
// ============================================

model EscalationRule {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  descriptionAr String?
  descriptionEn String?

  level1DelayHours Float
  level2DelayHours Float
  level3DelayHours Float

  level1RecipientSelector String // e.g. "entity.assignedTo"
  level2RecipientSelector String // e.g. "entity.assignedTo.manager"
  level3RecipientSelector String // e.g. "role:SUPER_ADMIN"

  channels String[] @default([])
  enabled  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances EscalationInstance[]

  @@map("escalation_rules")
}

// ============================================
// Sprint 10 — Reports & KPIs (M10-001)
// ============================================

model SavedReport {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation("ReportOwner", fields: [ownerId], references: [id])
  reportCode    String
  name          String
  filters       Json
  scheduledCron String?
  recipients    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([reportCode])
  @@map("saved_reports")
}

model EscalationInstance {
  id     String         @id @default(cuid())
  ruleId String
  rule   EscalationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  resource   String
  resourceId String

  triggeredAt     DateTime  @default(now())
  currentLevel    Int       @default(0)
  lastEscalatedAt DateTime?
  resolvedAt      DateTime?
  resolvedReason  String?

  @@unique([ruleId, resource, resourceId])
  @@index([resolvedAt])
  @@map("escalation_instances")
}

// ============================================
// Process correction 2026-05-21 — see docs/CORRECTED_CLIENT_JOURNEY.md
// ============================================

/// Singleton configuration that drives discount + quote approval routing.
/// One row per organisation. Owned by the CEO / Portal Admin. The Sales
/// Person can grant discounts up to `salesCeilingPct` without approval;
/// anything above flows through the configured tiered or sequential chain.
model PricingPolicy {
  id String @id @default(cuid())

  /// % discount the sales person can grant without approval.
  salesCeilingPct Float @default(5)

  /// Routing mode. TIERED = different approvers per discount band.
  /// SEQUENTIAL = each above-ceiling request goes through every approver
  /// in order.
  mode PricingPolicyMode @default(TIERED)

  /// Tiered config (when mode = TIERED). Array of
  /// `{ upToPct: number, approver: "MANAGER" | "CEO" }` rows.
  tiers Json @default("[]")

  /// Sequential config (when mode = SEQUENTIAL). Array of approvers in
  /// order, e.g. `[{ approver: "MANAGER", order: 1 }, { approver: "CEO", order: 2 }]`.
  sequence Json @default("[]")

  /// % VAT applied to quotes. Default 15% (Saudi VAT).
  vatPct Float @default(15)

  /// Currency code (ISO 4217). Default SAR.
  currency String @default("SAR")

  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("pricing_policy")
}

enum PricingPolicyMode {
  TIERED
  SEQUENTIAL
}

/// Project-scoped government licence (building permit, demolition permit,
/// civil-defense approval, MODON licence, commercial registration, etc.).
/// Replaces the standalone GovTransaction model — government work shows up
/// as licences inside normal projects, owned by the Department Engineer
/// assigned to the relevant phase.
model Licence {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Human-readable licence name, e.g. "Building Permit", "Civil Defense Approval".
  name String

  /// Name of the government portal where the licence is filed (free text).
  /// Examples: Balady, Salama Gateway, Etimad, Fursa, MODON, HCIS.
  portalName String

  /// URL of the licence record on the portal. Anyone with project access
  /// can click through to check status manually (no portal API integration).
  portalUrl String?

  /// Request / file ID returned by the portal upon application.
  requestId String?

  status          LicenceStatus @default(APPLIED)
  appliedDate     DateTime
  issuedDate      DateTime?
  rejectedDate    DateTime?
  rejectionReason String?

  /// Engineer (or manager) who applied for the licence. Stored as a plain
  /// user-ID string to avoid a back-relation on User.
  appliedById String?

  /// Last time anyone updated the licence record. Used to surface "Last
  /// checked: 4 days ago" on the row + drive the reminder cadence cron.
  lastCheckedAt DateTime?

  /// Reminder cadence in working days. Cron prompts the owner to check
  /// the portal at this cadence while status ∈ {Applied, UnderReview}.
  /// Default 5 working days; admin-configurable per row.
  reminderCadenceDays Int @default(5)

  /// Last time the reminder cron pinged the owner about this licence.
  /// Separate from lastCheckedAt (which reflects user action) so the cron
  /// can throttle itself without lying about user activity.
  lastReminderAt DateTime?

  /// If this licence is a re-application after a rejection, links to the
  /// rejected predecessor so the audit trail is preserved.
  parentLicenceId String?
  parentLicence   Licence?  @relation("LicenceRemediation", fields: [parentLicenceId], references: [id])
  remediations    Licence[] @relation("LicenceRemediation")

  /// Phases of this project that cannot start until this licence is `Issued`.
  blockedPhases Phase[] @relation("PhaseLicenceDependencies")

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId])
  @@index([status])
  @@index([appliedDate])
  @@index([deletedAt])
  @@map("licences")
}

enum LicenceStatus {
  /// Application submitted, waiting on authority review.
  APPLIED
  /// Authority has started review; expect comments / requests for info.
  UNDER_REVIEW
  /// Approved + issued. Unblocks dependent phases.
  ISSUED
  /// Authority rejected the application. Remediation = new linked licence.
  REJECTED
}

// ============================================
// RBAC v2 — permission-based access control
// Design: docs/architecture/abak-rbac-design.md
// Roles are DATA (composed from a fixed Permission catalog), not the
// legacy `UserRole` enum (kept above during migration, dropped later).
// ============================================

/// Data-scope applied to a scopeable permission within a role.
enum Scope {
  OWN
  DEPARTMENT
  ALL
}

enum DeptType {
  TECHNICAL
  SALES
  FINANCE
  HR
  EXECUTIVE
  SUPPORT
}

/// Fixed catalog of every action the system can gate. Developer-owned,
/// seeded; each key (e.g. "rfq:price_section") maps to a guarded action.
model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  module      String
  action      String
  description String?
  scopeable   Boolean @default(false)

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

/// A named bundle of permissions. Admin-owned data — created/edited freely.
model Role {
  id           String  @id @default(cuid())
  name         String  @unique
  nameAr       String?
  description  String?
  isSystem     Boolean @default(false)
  isAssignable Boolean @default(true)

  permissions RolePermission[]
  assignments RoleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  scope        Scope      @default(ALL)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// User <-> Role. A user may hold many roles; effective permissions = union.
model RoleAssignment {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
  @@map("role_assignments")
}

/// First-class org unit (distinct from ServiceCategory = price list).
/// Admin-manageable: create / rename / activate / deactivate / set manager.
model Department {
  id       String   @id @default(cuid())
  name     String   @unique
  nameAr   String?
  type     DeptType @default(TECHNICAL)
  isActive Boolean  @default(true)
  order    Int      @default(0)

  /// One of THIS department's own engineers; keeps engineer powers and
  /// additionally gets the manager bundle. @unique => manages at most one dept.
  managerId String? @unique
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id])

  members  User[]              @relation("DepartmentMembers")
  services DepartmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("departments")
}

/// Technical departments link to one or more billable services.
model DepartmentService {
  departmentId      String
  department        Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@id([departmentId, serviceCategoryId])
  @@index([serviceCategoryId])
  @@map("department_services")
}
