generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?

  role   UserRole   @default(SALES_REPRESENTATIVE)
  status UserStatus @default(ACTIVE)

  emailVerified        Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  refreshTokens RefreshToken[]
  assignedLeads Lead[]         @relation("LeadAssignee")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REPRESENTATIVE
  TECHNICAL_MANAGER
  FINANCE_MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Service Catalog
// ============================================

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  description String?
  code        String  @unique

  basePrice Float?
  unit      String?

  isActive Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  leads    Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([code])
  @@map("services")
}

// ============================================
// System Configuration
// ============================================

model SystemSetting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(STRING)

  description String?
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("system_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

// ============================================
// Module 1: Lead Capture & Reception
// ============================================

model Lead {
  id              String      @id @default(cuid())
  leadNumber      String      @unique
  channel         LeadChannel
  source          String?
  referenceNumber String?

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?

  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  serviceDetails  String?
  projectLocation String?
  projectSize     String?
  budget          Float?
  timeline        String?

  etimadNumber   String?
  fursaNumber    String?
  tenderDeadline DateTime?
  tenderDetails  Json?

  referredBy      String?
  referrerPhone   String?
  referrerCompany String?

  socialPlatform String?
  socialProfile  String?

  mapsLink   String?
  mapsReview Boolean?

  status       LeadStatus   @default(NEW)
  priority     LeadPriority @default(MEDIUM)
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  slaResponseDue  DateTime?
  slaStatus       SLAStatus @default(ON_TIME)
  firstResponseAt DateTime?

  isReturningClient Boolean @default(false)
  clientId          String?

  qualificationScore Int?    @default(0)
  qualificationNotes String?

  initialNotes String?
  lostReason   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  closedAt  DateTime?

  @@index([leadNumber])
  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([slaStatus])
  @@index([createdAt])
  @@index([serviceId])
  @@map("leads")
}

enum LeadChannel {
  GOVERNMENT_TENDER
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  WEBSITE
  GOOGLE_MAPS
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
  DUPLICATE
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SLAStatus {
  ON_TIME
  DUE_SOON
  OVERDUE
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String

  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
