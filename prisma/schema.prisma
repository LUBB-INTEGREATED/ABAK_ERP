generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?

  role   UserRole   @default(SALES_REPRESENTATIVE)
  status UserStatus @default(ACTIVE)

  // Localization preferences (M9-008)
  preferredLanguage           String @default("ar") // 'ar' | 'en'
  calendarDisplay             String @default("BOTH") // GREGORIAN | HIJRI | BOTH
  numeralSystem               String @default("LATIN") // LATIN | ARABIC_INDIC
  timezone                    String @default("Asia/Riyadh")
  notificationQuietHoursStart Int?   @default(22)
  notificationQuietHoursEnd   Int?   @default(7)

  emailVerified        Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  refreshTokens      RefreshToken[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  managedClients     Client[]          @relation("AccountManager")
  loggedInteractions Interaction[]     @relation("InteractionAuthor")
  assignedFollowUps  FollowUp[]        @relation("FollowUpAssignee")
  authoredNotes      ClientNote[]      @relation("NoteAuthor")
  pipelineEntries    PipelineEntry[]   @relation("PipelineOwner")
  stageChanges       StageTransition[] @relation("StageActor")
  loggedVisits       FieldVisit[]      @relation("VisitAuthor")
  salesTargets       SalesTarget[]     @relation("TargetOwner")
  preparedQuotes     Quote[]           @relation("QuotePreparer")
  approvals          QuoteApproval[]   @relation("QuoteApprover")

  coordinatedRfqs     Rfq[] @relation("RfqCoordinator")
  technicalRfqs       Rfq[] @relation("RfqTechContributor")
  financialReviewRfqs Rfq[] @relation("RfqFinancialReviewer")
  originatedRfqs      Rfq[] @relation("RfqOriginalSalesRep")

  managedProjects Project[] @relation("ProjectPM")
  ownedPhases     Phase[]   @relation("PhaseOwner")
  assignedTasks   Task[]    @relation("TaskAssignee")

  validatedPayments                Payment[]                @relation("PaymentValidator")
  validatedCommercialConfirmations CommercialConfirmation[] @relation("CommercialConfirmationValidator")

  assignedGovTransactionsAsPro      GovTransaction[] @relation("GovTxPro")
  assignedGovTransactionsAsEngineer GovTransaction[] @relation("GovTxEngineer")
  loggedGovVisits                   GovVisit[]       @relation("GovVisitPro")
  respondedGovComments              GovComment[]     @relation("GovCommentResponder")

  notifications Notification[] @relation("NotificationRecipient")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REPRESENTATIVE
  TECHNICAL_MANAGER
  FINANCE_MANAGER
  PRO
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Service Catalog
// ============================================

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  nameAr      String?
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  nameAr      String?
  nameEn      String?
  description String?
  code        String  @unique

  basePrice Float?
  unit      String?

  isActive Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  leads    Lead[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  QuoteItem QuoteItem[]

  @@index([categoryId])
  @@index([code])
  @@map("services")
}

// ============================================
// System Configuration
// ============================================

model SystemSetting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(STRING)

  labelAr         String?
  labelEn         String?
  descriptionAr   String?
  descriptionEn   String?
  defaultValue    String?
  minValue        Float?
  maxValue        Float?
  editableByRoles String[] @default([])

  description String?
  category    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  history SettingHistory[]

  @@index([category])
  @@map("system_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model SettingHistory {
  id          String        @id @default(cuid())
  settingId   String
  setting     SystemSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  oldValue    String?
  newValue    String
  changedById String?
  changedAt   DateTime      @default(now())

  @@index([settingId])
  @@index([changedAt])
  @@map("setting_history")
}

// ============================================
// Public Holidays (M9-002)
// ============================================

model PublicHoliday {
  id          String   @id @default(cuid())
  date        DateTime // date-only, stored as UTC midnight
  nameAr      String
  nameEn      String
  isRecurring Boolean  @default(false)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([isRecurring])
  @@map("public_holidays")
}

// ============================================
// Module 1: Lead Capture & Reception
// ============================================

model Lead {
  id              String      @id @default(cuid())
  leadNumber      String      @unique
  channel         LeadChannel
  source          String?
  referenceNumber String?

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?

  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  serviceDetails  String?
  projectLocation String?
  projectSize     String?
  budget          Float?
  timeline        String?

  etimadNumber   String?
  fursaNumber    String?
  tenderDeadline DateTime?
  tenderDetails  Json?

  referredBy      String?
  referrerPhone   String?
  referrerCompany String?

  socialPlatform String?
  socialProfile  String?

  mapsLink   String?
  mapsReview Boolean?

  status       LeadStatus   @default(NEW)
  priority     LeadPriority @default(MEDIUM)
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  slaResponseDue  DateTime?
  slaStatus       SLAStatus @default(ON_TIME)
  firstResponseAt DateTime?

  isReturningClient Boolean @default(false)
  clientId          String?
  client            Client? @relation(fields: [clientId], references: [id])

  pipelineEntry PipelineEntry?
  quotes        Quote[]

  qualificationScore Int?    @default(0)
  qualificationNotes String?

  initialNotes String?
  lostReason   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  closedAt  DateTime?
  deletedAt DateTime?

  @@index([leadNumber])
  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([slaStatus])
  @@index([createdAt])
  @@index([serviceId])
  @@index([deletedAt])
  @@index([clientId])
  @@map("leads")
}

enum LeadChannel {
  GOVERNMENT_TENDER
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  WEBSITE
  GOOGLE_MAPS
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
  DUPLICATE
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SLAStatus {
  ON_TIME
  DUE_SOON
  OVERDUE
}

// ============================================
// Module 2: CRM (Client Relationship Management)
// ============================================

model Client {
  id           String @id @default(cuid())
  clientNumber String @unique

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  country      String? @default("Saudi Arabia")
  postalCode   String?

  commercialRegistration String?
  taxId                  String?

  classification       ClientClassification @default(NEW)
  classificationManual Boolean              @default(false)
  status               ClientStatus         @default(ACTIVE)

  creditLimit  Float?
  paymentTerms String?

  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id])

  lifetimeValue     Float @default(0)
  satisfactionScore Int?

  notes           ClientNote[]
  interactions    Interaction[]
  followUps       FollowUp[]
  leads           Lead[]
  pipelineEntries PipelineEntry[]
  fieldVisits     FieldVisit[]
  quotes          Quote[]
  rfqs            Rfq[]
  purchaseOrders  PurchaseOrder[]
  projects        Project[]
  invoices        Invoice[]
  payments        Payment[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  lastInteractionAt DateTime?
  deletedAt         DateTime?

  @@index([clientNumber])
  @@index([classification])
  @@index([status])
  @@index([accountManagerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

enum ClientClassification {
  NEW
  RETURNING
  VIP
  DORMANT
  ARCHIVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Interaction {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type            InteractionType
  direction       InteractionDirection?
  subject         String
  summary         String?
  occurredAt      DateTime              @default(now())
  durationMinutes Int?

  location   String?
  outcome    String?
  nextAction String?

  authorId String?
  author   User?   @relation("InteractionAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([type])
  @@index([occurredAt])
  @@index([authorId])
  @@map("interactions")
}

enum InteractionType {
  PHONE_CALL
  MEETING
  EMAIL
  WHATSAPP
  COMPLAINT
  SITE_VISIT
  NEGOTIATION
  TECHNICAL_CONSULTATION
  PROPOSAL_SUBMISSION
  INTERNAL_NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model FollowUp {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        FollowUpType   @default(GENERAL)
  dueAt       DateTime
  status      FollowUpStatus @default(PENDING)

  assignedToId String?
  assignedTo   User?   @relation("FollowUpAssignee", fields: [assignedToId], references: [id])

  completedAt DateTime?
  outcome     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_ups")
}

enum FollowUpType {
  GENERAL
  QUOTE
  PAYMENT
  PROJECT_MILESTONE
  SATISFACTION_SURVEY
  RENEWAL
}

enum FollowUpStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

model ClientNote {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  body     String
  tag      NoteTag @default(GENERAL)
  authorId String?
  author   User?   @relation("NoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([createdAt])
  @@map("client_notes")
}

enum NoteTag {
  GENERAL
  IMPORTANT
  ISSUE
  OPPORTUNITY
}

// ============================================
// Module 3: Sales Pipeline & Team Management
// ============================================

model PipelineEntry {
  id    String        @id @default(cuid())
  stage PipelineStage @default(NEW_LEAD)

  leadId   String? @unique
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("PipelineOwner", fields: [ownerId], references: [id])

  estimatedValue  Float?
  probability     Int?      @default(10)
  expectedCloseAt DateTime?
  stageEnteredAt  DateTime  @default(now())
  lostReason      String?
  postponedUntil  DateTime?

  transitions StageTransition[]
  rfq         Rfq?

  nextStep      String?
  readyForRfqAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([stage])
  @@index([ownerId])
  @@index([clientId])
  @@index([leadId])
  @@index([expectedCloseAt])
  @@map("pipeline_entries")
}

enum PipelineStage {
  NEW_LEAD
  INITIAL_CONTACT
  QUALIFICATION
  READY_FOR_RFQ
  RFQ_RECEIVED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  POSTPONED
}

model StageTransition {
  id              String        @id @default(cuid())
  pipelineEntryId String
  pipelineEntry   PipelineEntry @relation(fields: [pipelineEntryId], references: [id], onDelete: Cascade)

  fromStage PipelineStage
  toStage   PipelineStage
  reason    String?

  actorId String?
  actor   User?   @relation("StageActor", fields: [actorId], references: [id])

  durationSeconds Int?
  occurredAt      DateTime @default(now())

  @@index([pipelineEntryId])
  @@index([occurredAt])
  @@map("stage_transitions")
}

model FieldVisit {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  visitType  VisitType
  purpose    String
  findings   String?
  nextAction String?

  scheduledAt   DateTime
  completedAt   DateTime?
  locationLabel String?
  latitude      Float?
  longitude     Float?
  attendees     String?

  authorId String?
  author   User?   @relation("VisitAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([authorId])
  @@index([scheduledAt])
  @@map("field_visits")
}

enum VisitType {
  INITIAL
  FOLLOW_UP
  TECHNICAL
  PRESENTATION
  CLOSING
}

model SalesTarget {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("TargetOwner", fields: [ownerId], references: [id])

  type          TargetType
  period        TargetPeriod
  periodStart   DateTime
  periodEnd     DateTime
  targetValue   Float
  achievedValue Float        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, type, period, periodStart])
  @@index([ownerId])
  @@map("sales_targets")
}

enum TargetType {
  REVENUE
  QUOTES_SENT
  CONVERSIONS
  VISITS
}

enum TargetPeriod {
  MONTHLY
  QUARTERLY
}

// ============================================
// Module 4: Quotation & Pricing Engine
// ============================================

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  version     Int         @default(1)
  status      QuoteStatus @default(DRAFT)

  clientId String
  client   Client  @relation(fields: [clientId], references: [id])
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id])

  title              String
  description        String?
  validUntil         DateTime?
  deliveryTimeline   String?
  paymentTerms       String?
  termsAndConditions String?
  internalNotes      String?
  clientNotes        String?

  subtotal       Float        @default(0)
  discountType   DiscountType @default(FIXED)
  discountValue  Float        @default(0)
  discountAmount Float        @default(0)
  taxRate        Float        @default(15)
  taxAmount      Float        @default(0)
  totalAmount    Float        @default(0)

  preparedById String?
  preparedBy   User?   @relation("QuotePreparer", fields: [preparedById], references: [id])

  sentAt         DateTime?
  viewedAt       DateTime?
  wonAt          DateTime?
  lostAt         DateTime?
  lostReasonCode LossReason?
  lostReason     String?
  postponedUntil DateTime?
  cancelledAt    DateTime?

  parentQuoteId String?
  parentQuote   Quote?  @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions     Quote[] @relation("QuoteRevisions")

  items                  QuoteItem[]
  paymentMilestones      PaymentMilestone[]
  approvals              QuoteApproval[]
  purchaseOrder          PurchaseOrder?
  rfq                    Rfq?
  commercialConfirmation CommercialConfirmation?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([quoteNumber])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([preparedById])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  IN_REVISION
  APPROVED
  SENT
  IN_DISCUSSION
  IN_NEGOTIATION
  REVISED
  WON
  LOST
  POSTPONED
  EXPIRED
  CANCELLED
}

// BR-11 — loss reasons come from a controlled vocabulary (doc PART 3.4)
enum LossReason {
  PRICE
  COMPETITOR
  SCOPE_MISMATCH
  BUDGET_UNAVAILABLE
  POSTPONED
  NO_RESPONSE
  QUALITY_CONCERN
  INTERNAL
  OTHER
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

model QuoteItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  description String
  quantity    Float
  unit        String?
  unitPrice   Float
  discountPct Float   @default(0)
  subtotal    Float   @default(0)
  notes       String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_items")
}

model PaymentMilestone {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description   String
  percentage    Float
  amount        Float
  daysFromStart Int?
  notes         String?
  position      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("payment_milestones")
}

model QuoteApproval {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  tier       Int
  approverId String
  approver   User   @relation("QuoteApprover", fields: [approverId], references: [id])

  status    ApprovalStatus @default(PENDING)
  decidedAt DateTime?
  comments  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([approverId])
  @@index([status])
  @@map("quote_approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique

  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  project  Project?
  invoices Invoice[]
  payments Payment[]

  poDate               DateTime  @default(now())
  startDate            DateTime?
  expectedCompletionAt DateTime?
  contractValue        Float
  status               POStatus  @default(ACTIVE)
  contractDocUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poNumber])
  @@index([clientId])
  @@index([status])
  @@map("purchase_orders")
}

enum POStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String

  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Module 3 — RFQ (Request For Quotation)  (M3-004)
// ============================================

model Rfq {
  id        String @id @default(cuid())
  rfqNumber String @unique

  opportunityId String        @unique
  opportunity   PipelineEntry @relation(fields: [opportunityId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])

  serviceType  String
  projectScope String
  priority     RfqPriority @default(NORMAL)

  requestedByChannel RfqSource
  brokerName         String?
  brokerPhone        String?

  coordinatorId         String?
  coordinator           User?     @relation("RfqCoordinator", fields: [coordinatorId], references: [id])
  coordinatorAssignedAt DateTime?

  technicalContributorId String?
  technicalContributor   User?   @relation("RfqTechContributor", fields: [technicalContributorId], references: [id])

  financialReviewerId String?
  financialReviewer   User?   @relation("RfqFinancialReviewer", fields: [financialReviewerId], references: [id])

  originalSalesRepId String?
  originalSalesRep   User?   @relation("RfqOriginalSalesRep", fields: [originalSalesRepId], references: [id])

  status RfqStatus @default(RECEIVED)

  quoteId       String?             @unique
  quote         Quote?              @relation(fields: [quoteId], references: [id])
  dispatchedAt  DateTime?
  dispatchedVia RfqDispatchChannel?

  confirmationType   ConfirmationType?
  confirmationAt     DateTime?
  confirmationValue  Float?
  confirmationDocUrl String?

  lostReason     String?
  postponedUntil DateTime?

  qualityScore  RfqQualityScore @default(PENDING)
  revisionCount Int             @default(0)

  commissions Commission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([rfqNumber])
  @@index([clientId])
  @@index([coordinatorId])
  @@index([status])
  @@index([createdAt])
  @@map("rfqs")
}

enum RfqStatus {
  RECEIVED
  ASSIGNED
  IN_PREPARATION
  PENDING_APPROVAL
  APPROVED_READY_FOR_DISPATCH
  SENT
  WON
  LOST
  POSTPONED
  CANCELLED
}

enum RfqSource {
  SALES_MANAGER
  INTERNAL_REP
  BROKER
  SOCIAL
  EMAIL
  WHATSAPP
}

enum RfqPriority {
  NORMAL
  HIGH
  URGENT
}

enum RfqDispatchChannel {
  WHATSAPP
  EMAIL
}

enum ConfirmationType {
  PAYMENT
  PO
  CONTRACT
}

enum RfqQualityScore {
  HIGH
  MEDIUM
  LOW
  PENDING
}

// ============================================
// Module 5 — Project Execution (M5-001)
// ============================================

model Project {
  id            String @id @default(cuid())
  projectNumber String @unique

  poId String        @unique
  po   PurchaseOrder @relation(fields: [poId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  opportunityId String?
  rfqId         String?

  title       String
  description String?

  pmId String
  pm   User   @relation("ProjectPM", fields: [pmId], references: [id])

  status          ProjectStatus @default(PLANNING)
  startDate       DateTime?
  expectedEndDate DateTime?
  actualEndDate   DateTime?

  contractValue   Float
  plannedProgress Float @default(0)
  actualProgress  Float @default(0)

  financialRiskFlagged   Boolean   @default(false)
  financialRiskFlaggedAt DateTime?
  financialRiskReason    String?

  phases           Phase[]
  tasks            Task[]
  closureChecklist ClosureChecklist?
  invoices         Invoice[]
  govTransactions  GovTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([projectNumber])
  @@index([clientId])
  @@index([pmId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  AT_RISK
  CLOSING
  CLOSED
  CANCELLED
}

model Phase {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  phaseCode   PhaseCode
  customLabel String?

  position Int
  ownerId  String
  owner    User   @relation("PhaseOwner", fields: [ownerId], references: [id])

  status       PhaseStatus @default(NOT_STARTED)
  plannedStart DateTime
  plannedEnd   DateTime
  actualStart  DateTime?
  actualEnd    DateTime?

  progressPct      Float   @default(0)
  pmAdjustment     Float?
  pmAdjustmentNote String?

  evidenceRequired     Boolean   @default(true)
  evidenceNote         String?
  clientAcknowledgedAt DateTime?
  completedAt          DateTime?
  completedById        String?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
  @@map("phases")
}

enum PhaseCode {
  INITIATION
  KICKOFF
  EXECUTION
  REVIEW
  SUBMISSION
  REVISIONS
  CLOSURE
  CUSTOM
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  UNDER_REVIEW
  COMPLETED
  SKIPPED
}

model Task {
  id        String  @id @default(cuid())
  projectId String
  phaseId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  assigneeId  String?
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  status   TaskStatus   @default(NOT_STARTED)
  priority TaskPriority @default(NORMAL)

  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  estimatedHours Float?
  actualHours    Float?

  blockers   TaskDependency[] @relation("DependentTask")
  dependents TaskDependency[] @relation("BlockerTask")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
  @@index([assigneeId])
  @@map("tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model TaskDependency {
  id          String @id @default(cuid())
  dependentId String
  blockerId   String
  dependent   Task   @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)
  blocker     Task   @relation("BlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([dependentId, blockerId])
  @@map("task_dependencies")
}

// PART 7 — Project Closure (M5-011)
model ClosureChecklist {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // PM-owned gates
  allPhasesCompleted         Boolean   @default(false)
  allPhasesCompletedAt       DateTime?
  allPhasesCompletedById     String?
  deliverablesSubmitted      Boolean   @default(false)
  deliverablesSubmittedAt    DateTime?
  deliverablesSubmittedById  String?
  clientApprovalReceived     Boolean   @default(false)
  clientApprovalReceivedAt   DateTime?
  clientApprovalReceivedById String?

  // Finance-owned gates
  finalPaymentReceived       Boolean   @default(false)
  finalPaymentReceivedAt     DateTime?
  finalPaymentReceivedById   String?
  financeClearanceIssued     Boolean   @default(false)
  financeClearanceIssuedAt   DateTime?
  financeClearanceIssuedById String?

  initiatedAt   DateTime  @default(now())
  initiatedById String?
  closedAt      DateTime?

  @@map("closure_checklists")
}

// ============================================
// Module 7 — Finance (Invoices, Payments, Commercial Confirmations, Commissions)
// ============================================

model CommercialConfirmation {
  id      String @id @default(cuid())
  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])

  type          ConfirmationType
  confirmedAt   DateTime         @default(now())
  contractValue Float
  docUrl        String?
  notes         String?

  validationStatus PaymentValidationStatus @default(PENDING)
  validatedAt      DateTime?
  validatedById    String?
  validatedBy      User?                   @relation("CommercialConfirmationValidator", fields: [validatedById], references: [id])
  validationNote   String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([validationStatus])
  @@map("commercial_confirmations")
}

enum PaymentValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  poId     String
  po       PurchaseOrder @relation(fields: [poId], references: [id])
  clientId String
  client   Client        @relation(fields: [clientId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  milestoneId String?

  issueDate   DateTime @default(now())
  dueDate     DateTime
  subtotal    Float
  taxAmount   Float
  totalAmount Float

  status InvoiceStatus @default(ISSUED)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([invoiceNumber])
  @@index([poId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Payment {
  id            String @id @default(cuid())
  paymentNumber String @unique

  invoiceId String?
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id])
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id])
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])

  receivedAt      DateTime
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  docUrl          String?

  validationStatus PaymentValidationStatus @default(PENDING)
  validatedAt      DateTime?
  validatedById    String?
  validatedBy      User?                   @relation("PaymentValidator", fields: [validatedById], references: [id])
  validationNote   String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([invoiceId])
  @@index([poId])
  @@index([clientId])
  @@index([validationStatus])
  @@map("payments")
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  ONLINE
  OTHER
}

model Commission {
  id    String @id @default(cuid())
  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id])

  beneficiaryType   CommissionBeneficiary
  beneficiaryName   String
  beneficiaryPhone  String?
  beneficiaryUserId String?

  baseAmount Float            @default(0)
  rate       Float
  amount     Float            @default(0)
  status     CommissionStatus @default(ACCRUING)
  paidAt     DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([status])
  @@map("commissions")
}

enum CommissionBeneficiary {
  BROKER
  SALES_REP
  REFERRAL_SOURCE
}

enum CommissionStatus {
  ACCRUING
  APPROVED
  PAID
  CANCELLED
}

// ============================================
// Module 6 — Government Transactions (M6-001)
// ============================================

model GovTransaction {
  id                String @id @default(cuid())
  transactionNumber String @unique

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorityName     String
  authorityCategory GovAuthorityCategory
  transactionType   String
  referenceNumber   String?

  assignedProId      String?
  assignedPro        User?   @relation("GovTxPro", fields: [assignedProId], references: [id])
  assignedEngineerId String?
  assignedEngineer   User?   @relation("GovTxEngineer", fields: [assignedEngineerId], references: [id])

  submittedAt        DateTime?
  expectedResponseAt DateTime?
  resolvedAt         DateTime?

  status     GovTxStatus @default(SUBMITTED)
  fees       Float?
  feesPaid   Boolean     @default(false)
  feesPaidAt DateTime?

  weeklyStatusLastAt DateTime?

  visits    GovVisit[]
  comments  GovComment[]
  documents GovDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([projectId])
  @@index([transactionNumber])
  @@index([assignedProId])
  @@index([status])
  @@map("gov_transactions")
}

enum GovAuthorityCategory {
  MUNICIPALITY
  MINISTRY
  UTILITY
  PLATFORM_ETIMAD
  PLATFORM_FURSA
  OTHER
}

enum GovTxStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUIRED
  APPROVED
  REJECTED
  CANCELLED
}

model GovVisit {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  visitedById String
  visitedBy   User     @relation("GovVisitPro", fields: [visitedById], references: [id])
  visitedAt   DateTime
  purpose     String
  outcome     String?
  nextAction  String?
  latitude    Float?
  longitude   Float?
  attachments Json?

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([visitedById])
  @@index([visitedAt])
  @@map("gov_visits")
}

model GovComment {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  commentText   String
  issuedAt      DateTime
  responseText  String?
  respondedAt   DateTime?
  respondedById String?
  respondedBy   User?     @relation("GovCommentResponder", fields: [respondedById], references: [id])

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@map("gov_comments")
}

model GovDocument {
  id            String         @id @default(cuid())
  transactionId String
  transaction   GovTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  title      String
  fileUrl    String
  mimeType   String?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@index([transactionId])
  @@map("gov_documents")
}

// ============================================
// Sprint 8 — Notifications (M8-001)
// ============================================

model Notification {
  id          String @id @default(cuid())
  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  eventCode String
  subject   String
  body      String
  locale    String               @default("ar")
  priority  NotificationPriority @default(NORMAL)

  deepLink String?
  payload  Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([eventCode])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// Sprint 11 — File Assets (M11-002)
// ============================================
//
// Minimum viable: assets are registered by URL (S3/CDN/etc). Direct upload
// + presign + virus scan deferred. Feature flag-free by design.

model FileAsset {
  id              String  @id @default(cuid())
  url             String
  originalName    String
  mimeType        String
  sizeBytes       Int
  uploadedById    String?
  ownerResource   String?
  ownerResourceId String?

  createdAt DateTime @default(now())

  @@index([ownerResource, ownerResourceId])
  @@map("file_assets")
}

// ============================================
// Sprint 11 — Escalation Ladder (M11-007, PART 8)
// ============================================

model EscalationRule {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  descriptionAr String?
  descriptionEn String?

  level1DelayHours Float
  level2DelayHours Float
  level3DelayHours Float

  level1RecipientSelector String // e.g. "entity.assignedTo"
  level2RecipientSelector String // e.g. "entity.assignedTo.manager"
  level3RecipientSelector String // e.g. "role:SUPER_ADMIN"

  channels String[] @default([])
  enabled  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances EscalationInstance[]

  @@map("escalation_rules")
}

model EscalationInstance {
  id     String         @id @default(cuid())
  ruleId String
  rule   EscalationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  resource   String
  resourceId String

  triggeredAt     DateTime  @default(now())
  currentLevel    Int       @default(0)
  lastEscalatedAt DateTime?
  resolvedAt      DateTime?
  resolvedReason  String?

  @@unique([ruleId, resource, resourceId])
  @@index([resolvedAt])
  @@map("escalation_instances")
}
