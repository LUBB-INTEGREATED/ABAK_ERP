generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?

  role   UserRole   @default(SALES_REPRESENTATIVE)
  status UserStatus @default(ACTIVE)

  emailVerified        Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  refreshTokens      RefreshToken[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  managedClients     Client[]          @relation("AccountManager")
  loggedInteractions Interaction[]     @relation("InteractionAuthor")
  assignedFollowUps  FollowUp[]        @relation("FollowUpAssignee")
  authoredNotes      ClientNote[]      @relation("NoteAuthor")
  pipelineEntries    PipelineEntry[]   @relation("PipelineOwner")
  stageChanges       StageTransition[] @relation("StageActor")
  loggedVisits       FieldVisit[]      @relation("VisitAuthor")
  salesTargets       SalesTarget[]     @relation("TargetOwner")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REPRESENTATIVE
  TECHNICAL_MANAGER
  FINANCE_MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Service Catalog
// ============================================

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  description String?
  code        String  @unique

  basePrice Float?
  unit      String?

  isActive Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  leads    Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([code])
  @@map("services")
}

// ============================================
// System Configuration
// ============================================

model SystemSetting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(STRING)

  description String?
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("system_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

// ============================================
// Module 1: Lead Capture & Reception
// ============================================

model Lead {
  id              String      @id @default(cuid())
  leadNumber      String      @unique
  channel         LeadChannel
  source          String?
  referenceNumber String?

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?

  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  serviceDetails  String?
  projectLocation String?
  projectSize     String?
  budget          Float?
  timeline        String?

  etimadNumber   String?
  fursaNumber    String?
  tenderDeadline DateTime?
  tenderDetails  Json?

  referredBy      String?
  referrerPhone   String?
  referrerCompany String?

  socialPlatform String?
  socialProfile  String?

  mapsLink   String?
  mapsReview Boolean?

  status       LeadStatus   @default(NEW)
  priority     LeadPriority @default(MEDIUM)
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  slaResponseDue  DateTime?
  slaStatus       SLAStatus @default(ON_TIME)
  firstResponseAt DateTime?

  isReturningClient Boolean @default(false)
  clientId          String?
  client            Client? @relation(fields: [clientId], references: [id])

  pipelineEntry PipelineEntry?

  qualificationScore Int?    @default(0)
  qualificationNotes String?

  initialNotes String?
  lostReason   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  closedAt  DateTime?
  deletedAt DateTime?

  @@index([leadNumber])
  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([slaStatus])
  @@index([createdAt])
  @@index([serviceId])
  @@index([deletedAt])
  @@index([clientId])
  @@map("leads")
}

enum LeadChannel {
  GOVERNMENT_TENDER
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  WEBSITE
  GOOGLE_MAPS
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
  DUPLICATE
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SLAStatus {
  ON_TIME
  DUE_SOON
  OVERDUE
}

// ============================================
// Module 2: CRM (Client Relationship Management)
// ============================================

model Client {
  id           String @id @default(cuid())
  clientNumber String @unique

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  country      String? @default("Saudi Arabia")
  postalCode   String?

  commercialRegistration String?
  taxId                  String?

  classification       ClientClassification @default(NEW)
  classificationManual Boolean              @default(false)
  status               ClientStatus         @default(ACTIVE)

  creditLimit  Float?
  paymentTerms String?

  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id])

  lifetimeValue     Float @default(0)
  satisfactionScore Int?

  notes           ClientNote[]
  interactions    Interaction[]
  followUps       FollowUp[]
  leads           Lead[]
  pipelineEntries PipelineEntry[]
  fieldVisits     FieldVisit[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  lastInteractionAt DateTime?
  deletedAt         DateTime?

  @@index([clientNumber])
  @@index([classification])
  @@index([status])
  @@index([accountManagerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

enum ClientClassification {
  NEW
  RETURNING
  VIP
  DORMANT
  ARCHIVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Interaction {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type            InteractionType
  direction       InteractionDirection?
  subject         String
  summary         String?
  occurredAt      DateTime              @default(now())
  durationMinutes Int?

  location   String?
  outcome    String?
  nextAction String?

  authorId String?
  author   User?   @relation("InteractionAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([type])
  @@index([occurredAt])
  @@index([authorId])
  @@map("interactions")
}

enum InteractionType {
  PHONE_CALL
  MEETING
  EMAIL
  WHATSAPP
  COMPLAINT
  SITE_VISIT
  NEGOTIATION
  TECHNICAL_CONSULTATION
  PROPOSAL_SUBMISSION
  INTERNAL_NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model FollowUp {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        FollowUpType   @default(GENERAL)
  dueAt       DateTime
  status      FollowUpStatus @default(PENDING)

  assignedToId String?
  assignedTo   User?   @relation("FollowUpAssignee", fields: [assignedToId], references: [id])

  completedAt DateTime?
  outcome     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_ups")
}

enum FollowUpType {
  GENERAL
  QUOTE
  PAYMENT
  PROJECT_MILESTONE
  SATISFACTION_SURVEY
  RENEWAL
}

enum FollowUpStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

model ClientNote {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  body     String
  tag      NoteTag @default(GENERAL)
  authorId String?
  author   User?   @relation("NoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([createdAt])
  @@map("client_notes")
}

enum NoteTag {
  GENERAL
  IMPORTANT
  ISSUE
  OPPORTUNITY
}

// ============================================
// Module 3: Sales Pipeline & Team Management
// ============================================

model PipelineEntry {
  id    String        @id @default(cuid())
  stage PipelineStage @default(NEW_LEAD)

  leadId   String? @unique
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("PipelineOwner", fields: [ownerId], references: [id])

  estimatedValue  Float?
  probability     Int?      @default(10)
  expectedCloseAt DateTime?
  stageEnteredAt  DateTime  @default(now())
  lostReason      String?
  postponedUntil  DateTime?

  transitions StageTransition[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([stage])
  @@index([ownerId])
  @@index([clientId])
  @@index([leadId])
  @@index([expectedCloseAt])
  @@map("pipeline_entries")
}

enum PipelineStage {
  NEW_LEAD
  INITIAL_CONTACT
  QUALIFICATION
  RFQ_RECEIVED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  POSTPONED
}

model StageTransition {
  id              String        @id @default(cuid())
  pipelineEntryId String
  pipelineEntry   PipelineEntry @relation(fields: [pipelineEntryId], references: [id], onDelete: Cascade)

  fromStage PipelineStage
  toStage   PipelineStage
  reason    String?

  actorId String?
  actor   User?   @relation("StageActor", fields: [actorId], references: [id])

  durationSeconds Int?
  occurredAt      DateTime @default(now())

  @@index([pipelineEntryId])
  @@index([occurredAt])
  @@map("stage_transitions")
}

model FieldVisit {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  visitType  VisitType
  purpose    String
  findings   String?
  nextAction String?

  scheduledAt   DateTime
  completedAt   DateTime?
  locationLabel String?
  latitude      Float?
  longitude     Float?
  attendees     String?

  authorId String?
  author   User?   @relation("VisitAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([authorId])
  @@index([scheduledAt])
  @@map("field_visits")
}

enum VisitType {
  INITIAL
  FOLLOW_UP
  TECHNICAL
  PRESENTATION
  CLOSING
}

model SalesTarget {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("TargetOwner", fields: [ownerId], references: [id])

  type          TargetType
  period        TargetPeriod
  periodStart   DateTime
  periodEnd     DateTime
  targetValue   Float
  achievedValue Float        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, type, period, periodStart])
  @@index([ownerId])
  @@map("sales_targets")
}

enum TargetType {
  REVENUE
  QUOTES_SENT
  CONVERSIONS
  VISITS
}

enum TargetPeriod {
  MONTHLY
  QUARTERLY
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String

  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
