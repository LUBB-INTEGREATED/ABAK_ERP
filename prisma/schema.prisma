generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management & Authentication
// ============================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?

  role   UserRole   @default(SALES_REPRESENTATIVE)
  status UserStatus @default(ACTIVE)

  // Localization preferences (M9-008)
  preferredLanguage           String @default("ar") // 'ar' | 'en'
  calendarDisplay             String @default("BOTH") // GREGORIAN | HIJRI | BOTH
  numeralSystem               String @default("LATIN") // LATIN | ARABIC_INDIC
  timezone                    String @default("Asia/Riyadh")
  notificationQuietHoursStart Int?   @default(22)
  notificationQuietHoursEnd   Int?   @default(7)

  emailVerified        Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  refreshTokens      RefreshToken[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  managedClients     Client[]          @relation("AccountManager")
  loggedInteractions Interaction[]     @relation("InteractionAuthor")
  assignedFollowUps  FollowUp[]        @relation("FollowUpAssignee")
  authoredNotes      ClientNote[]      @relation("NoteAuthor")
  pipelineEntries    PipelineEntry[]   @relation("PipelineOwner")
  stageChanges       StageTransition[] @relation("StageActor")
  loggedVisits       FieldVisit[]      @relation("VisitAuthor")
  salesTargets       SalesTarget[]     @relation("TargetOwner")
  preparedQuotes     Quote[]           @relation("QuotePreparer")
  approvals          QuoteApproval[]   @relation("QuoteApprover")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REPRESENTATIVE
  TECHNICAL_MANAGER
  FINANCE_MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Service Catalog
// ============================================

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  nameAr      String?
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  nameAr      String?
  nameEn      String?
  description String?
  code        String  @unique

  basePrice Float?
  unit      String?

  isActive Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  leads    Lead[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  QuoteItem QuoteItem[]

  @@index([categoryId])
  @@index([code])
  @@map("services")
}

// ============================================
// System Configuration
// ============================================

model SystemSetting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(STRING)

  labelAr         String?
  labelEn         String?
  descriptionAr   String?
  descriptionEn   String?
  defaultValue    String?
  minValue        Float?
  maxValue        Float?
  editableByRoles String[] @default([])

  description String?
  category    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  history SettingHistory[]

  @@index([category])
  @@map("system_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model SettingHistory {
  id          String        @id @default(cuid())
  settingId   String
  setting     SystemSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  oldValue    String?
  newValue    String
  changedById String?
  changedAt   DateTime      @default(now())

  @@index([settingId])
  @@index([changedAt])
  @@map("setting_history")
}

// ============================================
// Public Holidays (M9-002)
// ============================================

model PublicHoliday {
  id          String   @id @default(cuid())
  date        DateTime // date-only, stored as UTC midnight
  nameAr      String
  nameEn      String
  isRecurring Boolean  @default(false)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([isRecurring])
  @@map("public_holidays")
}

// ============================================
// Module 1: Lead Capture & Reception
// ============================================

model Lead {
  id              String      @id @default(cuid())
  leadNumber      String      @unique
  channel         LeadChannel
  source          String?
  referenceNumber String?

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?

  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  serviceDetails  String?
  projectLocation String?
  projectSize     String?
  budget          Float?
  timeline        String?

  etimadNumber   String?
  fursaNumber    String?
  tenderDeadline DateTime?
  tenderDetails  Json?

  referredBy      String?
  referrerPhone   String?
  referrerCompany String?

  socialPlatform String?
  socialProfile  String?

  mapsLink   String?
  mapsReview Boolean?

  status       LeadStatus   @default(NEW)
  priority     LeadPriority @default(MEDIUM)
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  slaResponseDue  DateTime?
  slaStatus       SLAStatus @default(ON_TIME)
  firstResponseAt DateTime?

  isReturningClient Boolean @default(false)
  clientId          String?
  client            Client? @relation(fields: [clientId], references: [id])

  pipelineEntry PipelineEntry?
  quotes        Quote[]

  qualificationScore Int?    @default(0)
  qualificationNotes String?

  initialNotes String?
  lostReason   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  closedAt  DateTime?
  deletedAt DateTime?

  @@index([leadNumber])
  @@index([channel])
  @@index([status])
  @@index([assignedToId])
  @@index([slaStatus])
  @@index([createdAt])
  @@index([serviceId])
  @@index([deletedAt])
  @@index([clientId])
  @@map("leads")
}

enum LeadChannel {
  GOVERNMENT_TENDER
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  WEBSITE
  GOOGLE_MAPS
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
  DUPLICATE
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SLAStatus {
  ON_TIME
  DUE_SOON
  OVERDUE
}

// ============================================
// Module 2: CRM (Client Relationship Management)
// ============================================

model Client {
  id           String @id @default(cuid())
  clientNumber String @unique

  contactName    String
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  country      String? @default("Saudi Arabia")
  postalCode   String?

  commercialRegistration String?
  taxId                  String?

  classification       ClientClassification @default(NEW)
  classificationManual Boolean              @default(false)
  status               ClientStatus         @default(ACTIVE)

  creditLimit  Float?
  paymentTerms String?

  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id])

  lifetimeValue     Float @default(0)
  satisfactionScore Int?

  notes           ClientNote[]
  interactions    Interaction[]
  followUps       FollowUp[]
  leads           Lead[]
  pipelineEntries PipelineEntry[]
  fieldVisits     FieldVisit[]
  quotes          Quote[]
  purchaseOrders  PurchaseOrder[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  lastInteractionAt DateTime?
  deletedAt         DateTime?

  @@index([clientNumber])
  @@index([classification])
  @@index([status])
  @@index([accountManagerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

enum ClientClassification {
  NEW
  RETURNING
  VIP
  DORMANT
  ARCHIVED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Interaction {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type            InteractionType
  direction       InteractionDirection?
  subject         String
  summary         String?
  occurredAt      DateTime              @default(now())
  durationMinutes Int?

  location   String?
  outcome    String?
  nextAction String?

  authorId String?
  author   User?   @relation("InteractionAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([type])
  @@index([occurredAt])
  @@index([authorId])
  @@map("interactions")
}

enum InteractionType {
  PHONE_CALL
  MEETING
  EMAIL
  WHATSAPP
  COMPLAINT
  SITE_VISIT
  NEGOTIATION
  TECHNICAL_CONSULTATION
  PROPOSAL_SUBMISSION
  INTERNAL_NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model FollowUp {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        FollowUpType   @default(GENERAL)
  dueAt       DateTime
  status      FollowUpStatus @default(PENDING)

  assignedToId String?
  assignedTo   User?   @relation("FollowUpAssignee", fields: [assignedToId], references: [id])

  completedAt DateTime?
  outcome     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_ups")
}

enum FollowUpType {
  GENERAL
  QUOTE
  PAYMENT
  PROJECT_MILESTONE
  SATISFACTION_SURVEY
  RENEWAL
}

enum FollowUpStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

model ClientNote {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  body     String
  tag      NoteTag @default(GENERAL)
  authorId String?
  author   User?   @relation("NoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([createdAt])
  @@map("client_notes")
}

enum NoteTag {
  GENERAL
  IMPORTANT
  ISSUE
  OPPORTUNITY
}

// ============================================
// Module 3: Sales Pipeline & Team Management
// ============================================

model PipelineEntry {
  id    String        @id @default(cuid())
  stage PipelineStage @default(NEW_LEAD)

  leadId   String? @unique
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("PipelineOwner", fields: [ownerId], references: [id])

  estimatedValue  Float?
  probability     Int?      @default(10)
  expectedCloseAt DateTime?
  stageEnteredAt  DateTime  @default(now())
  lostReason      String?
  postponedUntil  DateTime?

  transitions StageTransition[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([stage])
  @@index([ownerId])
  @@index([clientId])
  @@index([leadId])
  @@index([expectedCloseAt])
  @@map("pipeline_entries")
}

enum PipelineStage {
  NEW_LEAD
  INITIAL_CONTACT
  QUALIFICATION
  RFQ_RECEIVED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  POSTPONED
}

model StageTransition {
  id              String        @id @default(cuid())
  pipelineEntryId String
  pipelineEntry   PipelineEntry @relation(fields: [pipelineEntryId], references: [id], onDelete: Cascade)

  fromStage PipelineStage
  toStage   PipelineStage
  reason    String?

  actorId String?
  actor   User?   @relation("StageActor", fields: [actorId], references: [id])

  durationSeconds Int?
  occurredAt      DateTime @default(now())

  @@index([pipelineEntryId])
  @@index([occurredAt])
  @@map("stage_transitions")
}

model FieldVisit {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  visitType  VisitType
  purpose    String
  findings   String?
  nextAction String?

  scheduledAt   DateTime
  completedAt   DateTime?
  locationLabel String?
  latitude      Float?
  longitude     Float?
  attendees     String?

  authorId String?
  author   User?   @relation("VisitAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([authorId])
  @@index([scheduledAt])
  @@map("field_visits")
}

enum VisitType {
  INITIAL
  FOLLOW_UP
  TECHNICAL
  PRESENTATION
  CLOSING
}

model SalesTarget {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("TargetOwner", fields: [ownerId], references: [id])

  type          TargetType
  period        TargetPeriod
  periodStart   DateTime
  periodEnd     DateTime
  targetValue   Float
  achievedValue Float        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, type, period, periodStart])
  @@index([ownerId])
  @@map("sales_targets")
}

enum TargetType {
  REVENUE
  QUOTES_SENT
  CONVERSIONS
  VISITS
}

enum TargetPeriod {
  MONTHLY
  QUARTERLY
}

// ============================================
// Module 4: Quotation & Pricing Engine
// ============================================

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  version     Int         @default(1)
  status      QuoteStatus @default(DRAFT)

  clientId String
  client   Client  @relation(fields: [clientId], references: [id])
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id])

  title              String
  description        String?
  validUntil         DateTime?
  deliveryTimeline   String?
  paymentTerms       String?
  termsAndConditions String?
  internalNotes      String?
  clientNotes        String?

  subtotal       Float        @default(0)
  discountType   DiscountType @default(FIXED)
  discountValue  Float        @default(0)
  discountAmount Float        @default(0)
  taxRate        Float        @default(15)
  taxAmount      Float        @default(0)
  totalAmount    Float        @default(0)

  preparedById String?
  preparedBy   User?   @relation("QuotePreparer", fields: [preparedById], references: [id])

  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?

  items             QuoteItem[]
  paymentMilestones PaymentMilestone[]
  approvals         QuoteApproval[]
  purchaseOrder     PurchaseOrder?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([quoteNumber])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([preparedById])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  SENT
  VIEWED
  UNDER_NEGOTIATION
  REVISED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

model QuoteItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  description String
  quantity    Float
  unit        String?
  unitPrice   Float
  discountPct Float   @default(0)
  subtotal    Float   @default(0)
  notes       String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_items")
}

model PaymentMilestone {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description   String
  percentage    Float
  amount        Float
  daysFromStart Int?
  notes         String?
  position      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("payment_milestones")
}

model QuoteApproval {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  tier       Int
  approverId String
  approver   User   @relation("QuoteApprover", fields: [approverId], references: [id])

  status    ApprovalStatus @default(PENDING)
  decidedAt DateTime?
  comments  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([approverId])
  @@index([status])
  @@map("quote_approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique

  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  poDate               DateTime  @default(now())
  startDate            DateTime?
  expectedCompletionAt DateTime?
  contractValue        Float
  status               POStatus  @default(ACTIVE)
  contractDocUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poNumber])
  @@index([clientId])
  @@index([status])
  @@map("purchase_orders")
}

enum POStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================
// Audit Log
// ============================================

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String

  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
