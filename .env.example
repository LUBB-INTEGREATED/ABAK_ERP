## PostgreSQL (docker compose up -d abak-db spins up a local instance on 5433)
POSTGRES_USER=abak
POSTGRES_PASSWORD=abak
POSTGRES_DB=abak_erp
POSTGRES_PORT=5433

## Prisma — must match the docker-compose values above
DATABASE_URL="postgresql://abak:abak@localhost:5433/abak_erp?schema=public"

## Nest.js API
APP_PORT=3001
## Pick a free port if 3001 is taken by another local project, e.g. APP_PORT=3010
APP_GLOBAL_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

## Environment — set to `production` on the deployed box. In production the API
## REFUSES to boot without a strong JWT_SECRET (see config/env.validation.ts).
NODE_ENV=development

## Auth — REQUIRED. Must be a strong random value of at least 32 characters and
## MUST differ from the old dev fallback ("dev-secret-change-in-production-please").
## There is no built-in fallback: a missing/weak secret fails boot in production.
## Generate one with:  openssl rand -base64 48
JWT_SECRET=dev-secret-change-in-production-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_DAYS=7
BCRYPT_ROUNDS=10

## Destructive demo seed opt-in (NEVER set in production). The default
## `prisma db seed` runs the non-destructive RBAC seed. To run the demo seed
## that wipes and reseeds every table, use `npm run prisma:seed:demo`.
# ALLOW_DESTRUCTIVE_SEED=1
